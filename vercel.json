{
  "devCommand": "vite --port $PORT",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/$1"   },
    { "src": "/@(.*)",         "dest": "/@$1"       },
    { "src": "/__vite(.*)",    "dest": "/__vite$1"  },
    { "src": "/(.+\\.[^/]+)", "dest": "/$1"         },
    { "src": "/(.*)",          "dest": "/index.html" }
  ]
}
