{
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": { "includeFiles": "db/**" }
  },
  "buildCommand": "npm run build",
  "devCommand": "vite",
  "outputDirectory": "dist"
}
