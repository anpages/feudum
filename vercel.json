{
  "devCommand": "vite --port $PORT",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/cron/combat-engine",    "schedule": "* * * * *"    },
    { "path": "/api/cron/npc-builder",      "schedule": "* * * * *"    },
    { "path": "/api/cron/npc-military-ai",  "schedule": "*/20 * * * *" },
    { "path": "/api/cron/npc-health",       "schedule": "0 */4 * * *"  }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/$1"   },
    { "src": "/@(.*)",         "dest": "/@$1"       },
    { "src": "/__vite(.*)",    "dest": "/__vite$1"  },
    { "src": "/(.+\\.[^/]+)", "dest": "/$1"         },
    { "src": "/(.*)",          "dest": "/index.html" }
  ]
}
